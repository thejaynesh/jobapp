# Database
DATABASE_URL=postgresql://jobapp:jobapp@postgres:5432/jobapp
TEST_DATABASE_URL=postgresql://jobapp:jobapp@postgres:5432/jobapp_test

# Redis
REDIS_URL=redis://redis:6379/0

# LLM - NVIDIA NIM (OpenAI-compatible)
NVIDIA_NIM_API_KEY=your_key_here
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct

# Optional extra LLM providers. With a key set, resume/cover-letter generation
# prefers Claude, then Gemini, then NIM; job matching stays on NIM and uses
# these only as failover.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Outreach (optional)
HUNTER_IO_API_KEY=

# Job source API keys (all optional — leave blank to disable that source)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JSEARCH_API_KEY=
JOOBLE_API_KEY=                # free key: jooble.org/api/about
FINDWORK_API_KEY=              # free key: findwork.dev/developers
LINKEDIN_SESSION_COOKIE=
HANDSHAKE_SESSION_COOKIE=
GREENHOUSE_COMPANY_SLUGS=      # comma-separated slugs e.g. stripe,airbnb
LEVER_COMPANY_SLUGS=
ASHBY_COMPANY_SLUGS=
SMARTRECRUITERS_COMPANY_SLUGS=
WORKABLE_COMPANY_SLUGS=
RECRUITEE_COMPANY_SLUGS=
WORKDAY_TENANTS=               # tenant:host:site triples, e.g. nvidia:wd5:NVIDIAExternalCareerSite
ATS_AUTO_DISCOVERY=true        # learn company ATS boards from links in fetched jobs
ATS_SEED_COMPANIES=true        # include the verified seed list of well-known tech companies
ATS_SLUG_VALIDATION=true       # validate configured slugs against the ATS APIs and auto-fix
ATS_LIST_HARVEST=true          # harvest company slugs from community job lists (SimplifyJobs etc.)
#SLUG_HARVEST_URLS=            # override the default list URLs (comma-separated raw URLs)

# App
SECRET_KEY=change-me-in-production
DEBUG=false
STORAGE_PATH=/storage
MIN_MATCH_SCORE=70
FETCH_INTERVAL_HOURS=5
MIN_KEYWORD_SKILLS=2
MAX_JOB_AGE_DAYS=30           # skip fetched jobs posted longer ago than this (0 disables)
FILTER_SENIOR_TITLES=true     # drop Senior/Staff/Principal/Lead titles for junior candidates
JUNIOR_MAX_YEARS=3.0          # "junior" means fewer than this many years of experience
