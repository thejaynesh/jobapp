\documentclass[11pt,letterpaper]{article}
\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage[margin=0.65in]{geometry}
\usepackage[colorlinks=true, urlcolor=blue, linkcolor=blue]{hyperref}
\usepackage{enumitem}
\usepackage{titlesec}
\pagestyle{empty}
\raggedbottom

\titleformat{\section}{\large\bfseries}{}{0em}{}[\titlerule]
\titlespacing*{\section}{0pt}{8pt}{4pt}
\setlist[itemize]{noitemsep, topsep=2pt, leftmargin=1.2em}

\begin{document}

% Header
\begin{center}
  {\LARGE \textbf{ {{- profile.name | default("") | latex_escape -}} }}\\[4pt]
  {{- profile.contact.email | default("") | latex_escape }}%
  {% if profile.contact.phone %} \quad | \quad {{ profile.contact.phone | latex_escape }}{% endif %}%
  {% if profile.contact.location %} \quad | \quad {{ profile.contact.location | latex_escape }}{% endif %}%
  {% if profile.contact.linkedin %} \quad | \quad \href{ {{- profile.contact.linkedin -}} }{LinkedIn}{% endif %}%
  {% if profile.contact.github %} \quad | \quad \href{ {{- profile.contact.github -}} }{GitHub}{% endif %}%
  {% if profile.contact.website %} \quad | \quad \href{ {{- profile.contact.website -}} }{Website}{% endif %}
\end{center}

{% if narrative_summary %}
% Summary
\section{Summary}
{{ narrative_summary | latex_escape }}
{% endif %}

{% set non_empty_skills = [] %}
{% for category, items in skills.items() %}{% if items %}{% set _ = non_empty_skills.append(1) %}{% endif %}{% endfor %}
{% if non_empty_skills %}
% Skills
\section{Skills}
\begin{itemize}
{% for category, items in skills.items() %}
{% if items %}
  \item \textbf{ {{- category | title | latex_escape -}} :} {{ items | join(", ") | latex_escape }}
{% endif %}
{% endfor %}
\end{itemize}
{% endif %}

{% if experience %}
% Experience
\section{Experience}
{% for exp in experience %}
\textbf{ {{- exp.title | default("") | latex_escape -}} } \hfill {{ exp.start_date | default("") | latex_escape }} -- {{ exp.end_date | default("Present") | latex_escape }}\\
\textit{ {{- exp.company | default("") | latex_escape -}} }{% if exp.location %} \hfill {{ exp.location | latex_escape }}{% endif %}
{% if exp.bullets %}
\begin{itemize}
{% for bullet in exp.bullets %}
  \item {{ bullet | latex_escape }}
{% endfor %}
\end{itemize}
{% endif %}
{% endfor %}
{% endif %}

{% if education %}
% Education
\section{Education}
{% for edu in education %}
\textbf{ {{- edu.degree | default("") | latex_escape -}} } \hfill {{ edu.graduation_year | default("") | latex_escape }}\\
\textit{ {{- edu.school | default("") | latex_escape -}} }
{% endfor %}
{% endif %}

{% if projects %}
% Projects
\section{Projects}
{% for proj in projects %}
\textbf{ {{- proj.name | default("") | latex_escape -}} }{% if proj.url %} (\href{ {{- proj.url -}} }{link}){% endif %}\\
{% if proj.description %}{{ proj.description | latex_escape }}{% endif %}
{% if proj.bullets %}
\begin{itemize}
{% for bullet in proj.bullets %}
  \item {{ bullet | latex_escape }}
{% endfor %}
\end{itemize}
{% endif %}
{% endfor %}
{% endif %}

\end{document}
